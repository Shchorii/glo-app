# Copy to .env.local and fill in real values. NEVER commit real secrets.

# fal.ai
FAL_KEY=  # your fal.ai API key

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=       # dash.cloudflare.com account id
CLOUDFLARE_D1_DATABASE_ID=   # D1 database id
CLOUDFLARE_API_TOKEN=        # generate at dash.cloudflare.com/profile/api-tokens with D1 Edit scope

# Better-Auth
BETTER_AUTH_SECRET=  # openssl rand -base64 32
BETTER_AUTH_URL=https://app.we-are-glo.com

# Supabase (client — safe to expose, these are public keys)
NEXT_PUBLIC_SUPABASE_URL=       # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon/publishable key

# Supabase Edge Functions (server-side secrets — set via `supabase secrets set`)
SUPABASE_SERVICE_ROLE_KEY=  # service role key — server only, never expose to the client
SUPABASE_DB_URL=            # postgres connection string for Vault reads
OPENAI_API_KEY=             # support chat (GloBot)
STRIPE_SECRET_KEY=          # sk_live_... / sk_test_...
STRIPE_WEBHOOK_SECRET=      # whsec_...
